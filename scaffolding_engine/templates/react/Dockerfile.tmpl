# Build stage
FROM node:{{ .node_version }}-alpine AS build

WORKDIR /app

COPY package*.json ./
# 🔥 Upgrade: Strict, deterministic dependency resolution
RUN npm ci

COPY . .
RUN npm run build

# Production stage
FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html

# 1. Dynamically change default Nginx port from 80 to the injected app_port
# 2. Install curl for HEALTHCHECK
# 🔒 Checkov standard: Never run as root! (Strictly scoped permissions)
RUN apk add --no-cache curl && \
    sed -i 's/80/{{ .app_port }}/g' /etc/nginx/conf.d/default.conf && \
    addgroup -S appgroup && adduser -S appuser -G appgroup && \
    touch /var/run/nginx.pid && \
    chown -R appuser:appgroup \
        /usr/share/nginx/html \
        /var/cache/nginx \
        /var/log/nginx \
        /etc/nginx/conf.d \
        /var/run/nginx.pid

USER appuser

# 🩺 Healthcheck dynamically pointed at the injected app_port and health_path
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl --fail http://localhost:{{ .app_port }}{{ .health_path }} || exit 1

# Expose the dynamic port
EXPOSE {{ .app_port }}

# 🚀 Start Nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
