apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .app_name }}
  namespace: {{ .app_name }}-ns
spec:
  rules:
    - host: {{ .app_name }}.local
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ .app_name }}
                port:
                  number: 80
